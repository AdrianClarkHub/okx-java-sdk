# OKX Java SDK Spring Boot example configuration.
# Copy the okx section into your own application.yml or application-local.yml.
# Do not commit real API keys, secret keys, passphrases, proxy credentials, or local paths.

okx:
  environment: production
  default-account: main

  api-key: YOUR_API_KEY
  secret-key: YOUR_SECRET_KEY
  passphrase: YOUR_PASSPHRASE

  accounts:
    main:
      api-key: YOUR_MAIN_API_KEY
      secret-key: YOUR_MAIN_SECRET_KEY
      passphrase: YOUR_MAIN_PASSPHRASE
    demo:
      api-key: YOUR_DEMO_API_KEY
      secret-key: YOUR_DEMO_SECRET_KEY
      passphrase: YOUR_DEMO_PASSPHRASE

  http:
    connect-timeout-millis: 10000
    read-timeout-millis: 30000
    write-timeout-millis: 30000
    proxy:
      enabled: false
      host: YOUR_PROXY_HOST
      port: 7890
      username: YOUR_PROXY_USERNAME
      password: YOUR_PROXY_PASSWORD

  endpoints:
    rest-base-url: https://www.okx.com
    ws-public-url: wss://ws.okx.com:8443/ws/v5/public
    ws-private-url: wss://ws.okx.com:8443/ws/v5/private
    ws-business-url: wss://ws.okx.com:8443/ws/v5/business

  live:
    enabled: false
